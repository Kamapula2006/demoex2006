<Window x:Class="ShoeShop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ShoeShop"
        mc:Ignorable="d"
        Title="MainWindow" Height="333" Width="350" WindowStartupLocation="CenterScreen" ResizeMode="NoResize" Icon="/Images/Icon.ico">
    <Grid>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Image Source="/Images/Icon.png" Width="88"/>
            <TextBlock>email</TextBlock>
            <TextBox x:Name="emailtb"></TextBox>
            <TextBlock>password</TextBlock>
            <PasswordBox x:Name="passwordtb"/>
            <Button Click="Button_Click" Cursor="Hand">Войти</Button>
            <TextBlock MouseLeftButtonUp="TextBlock_MouseLeftButtonUp" Cursor="Hand">Войти как гость</TextBlock>
        </StackPanel>

    </Grid>
</Window>
<Window x:Class="Shoeshop2.Catalog"
        xmlns:conv="clr-namespace:Shoeshop2.Converters"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Shoeshop2"
        mc:Ignorable="d"
        Title="Каталог товаров" Height="550" Width="800">
    <Window.Resources>
        <conv:CrossedPriceConverter x:Key="CrossedPriceConverter" />
        <conv:ImagePathConverter x:Key="ImagePathConverter" />
        <conv:SaleToBackgroundConverter x:Key="SaleToBackgroundConverter" />
        <conv:FinalPriceConverter x:Key="FinalPriceConverter" />
        <conv:CountToBackgroundConverter x:Key="CountToBackgroundConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <Border Grid.Row="0" Background="LawnGreen">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="70"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0" Margin="5" 
                       Source="{Binding Converter={StaticResource ImagePathConverter}}"
                       HorizontalAlignment="Left"/>

                <TextBlock x:Name="UserNameTB" Grid.Column="2" 
                           Margin="10,5,10,0"
                           HorizontalAlignment="Right" 
                           VerticalAlignment="Top" 
                           FontWeight="Bold" FontSize="14"/>

                <Button x:Name="exBtn" Grid.Column="2" 
                        Width="80" Margin="10,25,10,5"
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Bottom"
                        Click="exBtn_Click" 
                        Content="Выйти" 
                        Cursor="Hand"/>
            </Grid>
        </Border>


        <Grid x:Name="SortGrid" Grid.Row="1" Visibility="Collapsed" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="200"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="5">
                <TextBlock Text="Поиск" FontSize="12"/>
                <TextBox x:Name="SearchTB" Height="30" BorderThickness="2" 
                         TextChanged="SearchTB_TextChanged"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="5">
                <TextBlock Text="Поставщик" FontSize="12"/>
                <ComboBox x:Name="SuppierCB" Height="30"
                          DisplayMemberPath="SupName" 
                          SelectedValuePath="IdSup" 
                          SelectionChanged="SuppierCB_SelectionChanged"/>
            </StackPanel>

            <StackPanel Grid.Column="2" Margin="5" Cursor="">
                <TextBlock Text="Сортировка по цене" FontSize="12"/>
                <ComboBox x:Name="SortCB" Height="30"
                          SelectionChanged="SortCB_SelectionChanged">
                    <ComboBoxItem Content="Без сортировки" IsSelected="True"/>
                    <ComboBoxItem Content="По возрастанию"/>
                    <ComboBoxItem Content="По убыванию"/>
                </ComboBox>
            </StackPanel>
        </Grid>


        <ListBox x:Name="prodList" Grid.Row="2" 
                 BorderThickness="0" 
                 Margin="5"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    <Setter Property="Padding" Value="0"/>
                    <Setter Property="Margin" Value="0,2"/>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Border BorderBrush="Gray" BorderThickness="1" Margin="2"
                            Background="{Binding Count, Converter={StaticResource CountToBackgroundConverter}}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="80"/>
                            </Grid.ColumnDefinitions>


                            <Border Grid.Column="0" Margin="5" 
                                    BorderBrush="Gray" BorderThickness="1">
                                <Image Source="{Binding Image, Converter={StaticResource ImagePathConverter}}"
                                       Width="140" Height="120" Stretch="Uniform"/>
                            </Border>


                            <StackPanel Grid.Column="1" Margin="10,5" VerticalAlignment="Center">
                                <TextBlock FontWeight="Bold" FontSize="13">
                                    <Run Text="{Binding Cat.CatName}"/>
                                    <Run Text=" | "/>
                                    <Run Text="{Binding ProdNameNavigation.ProdName1}"/>
                                </TextBlock>
                                <TextBlock Text="Описание:" FontWeight="Bold" Margin="0,3,0,0"/>
                                <TextBlock Text="{Binding Descrip}" TextWrapping="Wrap" Margin="0,0,0,5"/>
                                <TextBlock Text="{Binding Manuf.ManufName, StringFormat='Производитель: {0}'}"/>
                                <TextBlock Text="{Binding Sup.SupName, StringFormat='Поставщик: {0}'}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,5">
                                    <TextBlock FontWeight="Bold" Foreground="Black"
                                               Text="{Binding Converter={StaticResource FinalPriceConverter}}"/>
                                    <TextBlock Foreground="Red" Margin="8,0,0,0"
                                               Text="{Binding Converter={StaticResource CrossedPriceConverter}}"
                                               TextDecorations="Strikethrough"/>
                                </StackPanel>
                                <TextBlock Text="Единица измерения: шт"/>
                                <TextBlock Text="{Binding Count, StringFormat='Количество на складе: {0}'}"/>
                            </StackPanel>

                            <Border Grid.Column="2" Margin="5"
                                    BorderBrush="Gray" BorderThickness="1"
                                    Background="{Binding Sale, Converter={StaticResource SaleToBackgroundConverter}}">
                                <TextBlock HorizontalAlignment="Center" 
                                           VerticalAlignment="Center" 
                                           FontWeight="Bold"
                                           Text="{Binding Sale, StringFormat='-{0}%'}"/>
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</Window>